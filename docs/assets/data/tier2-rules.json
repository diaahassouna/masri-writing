  "alphabet": [
    { "no": 1,  "letter_upper": "A", "letter_lower": "a", "arabic": "ا", "name": "Alef",  "ipa": "/ʔ/, /aː/", "unicode_upper": "U+0041", "unicode_lower": "U+0061", "origin": "ASCII", "notes": "Open vowel; /aː/ as in 'father'" },
    { "no": 2,  "letter_upper": "B", "letter_lower": "b", "arabic": "ب", "name": "Beh",   "ipa": "/b/",        "unicode_upper": "U+0042", "unicode_lower": "U+0062", "origin": "ASCII", "notes": "Identical in all systems" },
    { "no": 3,  "letter_upper": "P", "letter_lower": "p", "arabic": "پ", "name": "Pee",   "ipa": "/p/",        "unicode_upper": "U+0050", "unicode_lower": "U+0070", "origin": "ASCII", "notes": "Foreign loanwords only; p ≠ b" },
    { "no": 4,  "letter_upper": "T", "letter_lower": "t", "arabic": "ت", "name": "Teh",   "ipa": "/t/",        "unicode_upper": "U+0054", "unicode_lower": "U+0074", "origin": "ASCII", "notes": "Identical in all systems" },
    { "no": 5,  "letter_upper": "Θ", "letter_lower": "θ", "arabic": "ث", "name": "Ṯeh",   "ipa": "/θ/ → /s/",  "unicode_upper": "U+0398", "unicode_lower": "U+03B8", "origin": "Greek",  "notes": "Greek theta; Cairene merger → /s/ (Tier 1 uses s or t)" },
    { "no": 6,  "letter_upper": "G", "letter_lower": "g", "arabic": "ج", "name": "Geem",  "ipa": "/g/",        "unicode_upper": "U+0047", "unicode_lower": "U+0067", "origin": "ASCII", "notes": "Hard G; never /dʒ/ in Cairo" },
    { "no": 7,  "letter_upper": "Ϩ", "letter_lower": "ϩ", "arabic": "ح", "name": "Ḥa",    "ipa": "/ħ/",        "unicode_upper": "U+03E8", "unicode_lower": "U+03E9", "origin": "Coptic", "notes": "Coptic Hori; mirrors shape of ح; never numeral 7" },
    { "no": 8,  "letter_upper": "X", "letter_lower": "x", "arabic": "خ", "name": "Ḵa",    "ipa": "/x/",        "unicode_upper": "U+0058", "unicode_lower": "U+0078", "origin": "ASCII", "notes": "Pan-European /x/" },
    { "no": 9,  "letter_upper": "D", "letter_lower": "d", "arabic": "د", "name": "Daal",  "ipa": "/d/",        "unicode_upper": "U+0044", "unicode_lower": "U+0064", "origin": "ASCII", "notes": "Identical in all systems" },
    { "no": 10, "letter_upper": "Ð", "letter_lower": "ð", "arabic": "ذ", "name": "Ḏaal",  "ipa": "/ð/ → /z/",  "unicode_upper": "U+00D0", "unicode_lower": "U+00F0", "origin": "Latin ext.", "notes": "Eth; Cairene merger /ð/→/z/, Masri reflects phonetic reality" },
    { "no": 11, "letter_upper": "R", "letter_lower": "r", "arabic": "ر", "name": "Reh",   "ipa": "/r/",        "unicode_upper": "U+0052", "unicode_lower": "U+0072", "origin": "ASCII", "notes": "Identical in all systems" },
    { "no": 12, "letter_upper": "Z", "letter_lower": "z", "arabic": "ز", "name": "Zeen",  "ipa": "/z/",        "unicode_upper": "U+005A", "unicode_lower": "U+007A", "origin": "ASCII", "notes": "Identical in all systems" },
    { "no": 13, "letter_upper": "S", "letter_lower": "s", "arabic": "س", "name": "Seen",  "ipa": "/s/",        "unicode_upper": "U+0053", "unicode_lower": "U+0073", "origin": "ASCII", "notes": "Identical in all systems" },
    { "no": 14, "letter_upper": "Ϣ", "letter_lower": "ϣ", "arabic": "ش", "name": "Sheen", "ipa": "/ʃ/",        "unicode_upper": "U+03E2", "unicode_lower": "U+03E3", "origin": "Coptic", "notes": "Coptic Shai; dotless ش skeleton; replaces sh digraph" },
    { "no": 15, "letter_upper": "Ṣ", "letter_lower": "ṣ", "arabic": "ص", "name": "Ṣaad",  "ipa": "/sˤ/",       "unicode_upper": "U+1E62", "unicode_lower": "U+1E63", "origin": "Latin ext.", "notes": "Emphatic; dot-below rule applies to Ṣ Ḍ Ṭ Ẓ" },
    { "no": 16, "letter_upper": "Ḍ", "letter_lower": "ḍ", "arabic": "ض", "name": "Ḍaad",  "ipa": "/dˤ/",       "unicode_upper": "U+1E0C", "unicode_lower": "U+1E0D", "origin": "Latin ext.", "notes": "Emphatic D" },
    { "no": 17, "letter_upper": "Ṭ", "letter_lower": "ṭ", "arabic": "ط", "name": "Ṭah",   "ipa": "/tˤ/",       "unicode_upper": "U+1E6C", "unicode_lower": "U+1E6D", "origin": "Latin ext.", "notes": "Emphatic T" },
    { "no": 18, "letter_upper": "Ẓ", "letter_lower": "ẓ", "arabic": "ظ", "name": "Ẓah",   "ipa": "/ðˤ/",       "unicode_upper": "U+1E92", "unicode_lower": "U+1E93", "origin": "Latin ext.", "notes": "Merges with Ḍ in most Cairene contexts" },
    { "no": 19, "letter_upper": "Ⲵ", "letter_lower": "Ⲵ", "arabic": "ع", "name": "ʿAin",  "ipa": "/ʕ/",        "unicode_upper": "U+2CB4", "unicode_lower": "U+2CB4", "origin": "Coptic", "notes": "Coptic Old Ain; uppercase = lowercase for visual consistency; descends from hieroglyph for 'eye'" },
    { "no": 20, "letter_upper": "Ɣ", "letter_lower": "ɣ", "arabic": "غ", "name": "Gheen", "ipa": "/ɣ/",        "unicode_upper": "U+0194", "unicode_lower": "U+0263", "origin": "Greek",  "notes": "IPA voiced velar fricative; Greek gamma" },
    { "no": 21, "letter_upper": "F", "letter_lower": "f", "arabic": "ف", "name": "Feh",   "ipa": "/f/",        "unicode_upper": "U+0046", "unicode_lower": "U+0066", "origin": "ASCII", "notes": "Identical in all systems" },
    { "no": 22, "letter_upper": "V", "letter_lower": "v", "arabic": "ڤ", "name": "Vee",   "ipa": "/v/",        "unicode_upper": "U+0056", "unicode_lower": "U+0076", "origin": "ASCII", "notes": "Foreign loanwords only; v ≠ f, both original phonemes" },
    { "no": 23, "letter_upper": "Q", "letter_lower": "q", "arabic": "ق", "name": "Qaaf",  "ipa": "/q/",        "unicode_upper": "U+0051", "unicode_lower": "U+0071", "origin": "ASCII", "notes": "Full /q/ for MSA/formal registers; colloquial Cairene → glottal Ɐ" },
    { "no": 24, "letter_upper": "K", "letter_lower": "k", "arabic": "ك", "name": "Kaaf",  "ipa": "/k/",        "unicode_upper": "U+004B", "unicode_lower": "U+006B", "origin": "ASCII", "notes": "Identical in all systems" },
    { "no": 25, "letter_upper": "L", "letter_lower": "l", "arabic": "ل", "name": "Laam",  "ipa": "/l/",        "unicode_upper": "U+004C", "unicode_lower": "U+006C", "origin": "ASCII", "notes": "Identical in all systems" },
    { "no": 26, "letter_upper": "M", "letter_lower": "m", "arabic": "م", "name": "Meem",  "ipa": "/m/",        "unicode_upper": "U+004D", "unicode_lower": "U+006D", "origin": "ASCII", "notes": "Identical in all systems" },
    { "no": 27, "letter_upper": "N", "letter_lower": "n", "arabic": "ن", "name": "Noon",  "ipa": "/n/",        "unicode_upper": "U+004E", "unicode_lower": "U+006E", "origin": "ASCII", "notes": "Identical in all systems" },
    { "no": 28, "letter_upper": "H", "letter_lower": "h", "arabic": "ه", "name": "Heh",   "ipa": "/h/",        "unicode_upper": "U+0048", "unicode_lower": "U+0068", "origin": "ASCII", "notes": "Soft H as in 'hat'; distinct from pharyngeal Ϩ" },
    { "no": 29, "letter_upper": "O", "letter_lower": "o", "arabic": "و", "name": "Oh",    "ipa": "/ʔo/, /o/",  "unicode_upper": "U+004F", "unicode_lower": "U+006F", "origin": "Vowel/semivowel", "notes": "Waw as long vowel /oː/" },
    { "no": 30, "letter_upper": "U", "letter_lower": "u", "arabic": "و", "name": "Ū",     "ipa": "/ʔu/, /u/",  "unicode_upper": "U+0055", "unicode_lower": "U+0075", "origin": "Vowel/semivowel", "notes": "Waw as long vowel /uː/" },
    { "no": 31, "letter_upper": "W", "letter_lower": "w", "arabic": "و", "name": "Dablew","ipa": "/ʔw/, /w/",  "unicode_upper": "U+0057", "unicode_lower": "U+0077", "origin": "Vowel/semivowel", "notes": "Waw as consonant /w/" },
    { "no": 32, "letter_upper": "E", "letter_lower": "e", "arabic": "ي", "name": "Ee",    "ipa": "/ʔe/, /e/",  "unicode_upper": "U+0045", "unicode_lower": "U+0065", "origin": "Vowel/semivowel", "notes": "Ya as long vowel /eː/" },
    { "no": 33, "letter_upper": "I", "letter_lower": "i", "arabic": "ي", "name": "Ai",    "ipa": "/ʔi/, /i/",  "unicode_upper": "U+0049", "unicode_lower": "U+0069", "origin": "Vowel/semivowel", "notes": "Ya as long vowel /iː/" },
    { "no": 34, "letter_upper": "Y", "letter_lower": "y", "arabic": "ي", "name": "Wye",   "ipa": "/ʔj/, /j/",  "unicode_upper": "U+0059", "unicode_lower": "U+0079", "origin": "Vowel/semivowel", "notes": "Ya as consonant /j/ (as in 'yes')" },
    { "no": 35, "letter_upper": "Ɐ", "letter_lower": "ɐ", "arabic": "ء", "name": "Hamza", "ipa": "/ʔ/",        "unicode_upper": "U+2C6F", "unicode_lower": "U+2C6F", "origin": "Latin ext.", "notes": "Upside-down A; glottal stop; mirror of Alef (open ↔ closed); represents ء, ق-Cairene, and all hamza forms (أ ؤ ئ) uniformly; always silent word-initially" }
  ],

  "borrowed_orthography": [
    { "letter_upper": "C", "letter_lower": "c", "arabic": "—", "name": "See",  "ipa": "/s/, /k/", "unicode_upper": "U+0043", "unicode_lower": "U+0063", "notes": "Restricted to code-switched words kept in original spelling" },
    { "letter_upper": "J", "letter_lower": "j", "arabic": "چ", "name": "Jéh",  "ipa": "/d͜ʒ/",     "unicode_upper": "U+004A", "unicode_lower": "U+006A", "notes": "Restricted to code-switched words kept in original spelling" }
