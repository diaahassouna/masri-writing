  "vowel_system": {
    "short_vowels": [
      { "arabic": "فتحة", "sound": "a (short)", "tier2": "a" },
      { "arabic": "ضمة",  "sound": "u (short)", "tier2": "u" },
      { "arabic": "كسرة", "sound": "i (short)", "tier2": "i" },
      { "arabic": "schwa/unstressed", "sound": "ə (often omitted)", "tier2": "ə (often omitted)", "example": "mⲴleϣϣ vs məttəⲴ" }
    ],
    "long_vowels": [
      { "arabic": "ا / آ", "sound": "ā (long a)", "tier2": "ā" },
      { "arabic": "و",     "sound": "ū (long u)", "tier2": "ū" },
      { "arabic": "ي",     "sound": "ī (long i)", "tier2": "ī" }
    ],
    "diphthongs": [
      { "arabic": "ـَي", "sound": "ay/ei", "spelling": "ay" },
      { "arabic": "ـَو", "sound": "aw/ou", "spelling": "aw" }
    ],
    "rule": "Short vowels are optional in fluent writing but required in ambiguous contexts and learning materials."
  },

  "ayin_rule": {
    "title": "The ع Problem — Most Critical Rule",
    "tier1_symbol": "` (backtick)",
    "tier2_symbol": "Ⲵ (Coptic Old Ain, U+2CB4)",
    "note": "In Tier 2, ع is always represented by Ⲵ (uppercase = lowercase for visual consistency).",
    "examples": [
      { "arabic": "عارف",  "wrong_vowel_only": "aref",   "tier1": "`aref",   "tier2": "Ⲵaref",   "meaning": "knowing" },
      { "arabic": "بعدين", "wrong_vowel_only": "badeen", "tier1": "ba`deen", "tier2": "baⲴdeen", "meaning": "afterwards" },
      { "arabic": "عشان",  "wrong_vowel_only": "ashan",  "tier1": "`ashan",  "tier2": "Ⲵaϣan",   "meaning": "because/for" },
      { "arabic": "على",   "wrong_vowel_only": "ala",    "tier1": "`ala",    "tier2": "Ⲵala",    "meaning": "on/upon" },
      { "arabic": "معاك",  "wrong_vowel_only": "maak",   "tier1": "ma`ak",   "tier2": "maⲴak",   "meaning": "with you" }
    ]
  },

  "spelling_rules": [
    {
      "id": 1,
      "name": "Gemination (Doubled consonants)",
      "rule": "Doubled consonants are written doubled.",
      "examples": ["حُبّ → hobb / Ϩobb", "جدا → geddan"]
    },
    {
      "id": 2,
      "name": "Definite Article",
      "rule": "Always written 'el' regardless of sun/moon-letter assimilation in speech. Spelling consistency is prioritized over phonetic transcription to reduce writer decision load.",
      "examples": ["البيت → el beet", "الشارع → el ϣaareⲴ"]
    },
    {
      "id": 3,
      "name": "Glottal Stop",
      "rule": "Written only mid-word and word-finally, using Ɐ in Tier 2 (apostrophe ' in Tier 1). Word-initial glottal stop — whether etymological ء or Cairene ق — is always silent in spelling and encoded.",
      "examples": ["أنا → ana (not Ɐana)", "مسئولية → masⱯooleya"]
    },
    {
      "id": 4,
      "name": "Digraph Integrity",
      "rule": "Applies to Tier 1 only (sh/kh/gh as inseparable two-letter units). In Tier 2 these are single letters (ϣ, x, ɣ) so this rule is not applicable.",
      "tier2_note": "Superseded by single-character mapping: sh→ϣ, kh→x, gh→ɣ"
    },
    {
      "id": 5,
      "name": "Cairene ق and Hamza Merger",
      "rule": "Ɐ represents the glottal phoneme regardless of etymological origin. Cairene ق and hamza are treated as a single phoneme (glottal stop) because they are phonetically identical in the Cairene dialect; q is reserved for formal/MSA pronunciation.",
      "examples": ["قال → Ɐaal (everyday: 'aal)", "قرآن → Qur'an (formal, retains q)"]
    },
    {
      "id": 6,
      "name": "The Letters P and V",
      "rule": "P and V are full, independent letters, not interchangeable with B or F. p is used mainly in loanwords/modern vocabulary; v is an original, coexisting phoneme.",
      "examples": ["بيانو → piano (not biano)", "بنك → bank", "أوفر → over"]
    }
  ],

