  "sample_texts": {
    "tier2_academic": "Ana baϨeb Maṣr. El ahwa el maṣreyya aϨsan ahwa fi el donya. Keda miϣ ra'y, dah ϨaⱯiⱯa.",
    "tier1_everyday": "Ana baheb Masr. El ahwa el masreya ahesan ahwa fi el donya. Keda mesh ra'y, dah ha'i'a (haqiqa).",
    "arabic_script": "أنا بحب مصر. القهوة المصرية أحسن قهوة في الدنيا. كدة مش رأي. دة حقيقة.",
    "stress_test_sentences_tier2": [
      "Ana Ⲵarif inno el loɣa el maṣreya aϨsan loɣa fi el donya, we da elli xallāni aϣtaɣal feha koll yoom.",
      "El ott el adeem baⲴdeen ge el beet we Ϩabbeto geddan — howa el waϨeed elli miϣ meⲴaⱯadni.",
      "Bass lamma Ϩawwelt aṭbaⲴ el awraaⱯ el mohemma kanet el printer miϣ ϣaɣɣala lel asaf Ⲵaϣan el power cable miϣ mawgood.",
      "El ḍabⲴ da ẓahar ṭabⲴan we el mawḍooⲴ da etⲴaⱯad xalaaṣ.",
      "Inϣāllāh bokra nϣūf, elϨamdillāh Ⲵandena waⱯt.",
      "El moϣkela en el ϣaɣɣāla el xeϣna el ɣaϣeema el over ɣalaṭatha ziyāda fe el θamarāt.",
      "We ewⲴa el ouda elli goowa el beet el beeⱯa elli fi el ϣaariⲴ el mahgoor laϨsan hatexsar keteer.",
      "ForⱯoⲴlowz raⱯaṣ Ⲵa el sellem we bass keda ya sidi we el meⲴallem Sardeena dafaⲴ feloos keteer lel ṣowaan we el farsha Ⲵa el ard.",
      "Oom oⱯaf we enta betkallemni, Oom oⱯaf boṣṣeli we fahhemni.",
      "EϨna benⱯool aaxer madena heyya madenet el Salaam ya abo el Ⲵorréf, matlaɣweϣϣi Ⲵalayya we balaaϣ avwara ya over enta."
    ]
  },

  "design_principles": [
    "One symbol per sound: each sound maps to exactly one symbol and vice versa.",
    "Simplicity prioritized over aesthetics: speed and ease over formal elegance.",
    "Cairene reference dialect: urban Cairo Egyptian Arabic is the normative standard.",
    "No numerals: no Arabic or Western numeral substitutes a letter.",
    "Keyboard accessibility (Tier 1): everyday symbols typeable on standard Latin keyboards; Tier 2 requires supplementary Greek/Coptic input."
  ],

  "origin_legend": {
    "ASCII": "Standard ASCII characters, no special input needed",
    "Coptic": "Ϩ (U+03E8), Ϣ (U+03E2), Ⲵ (U+2CB4)",
    "Greek": "Θ (U+0398), Ɣ (U+0194)",
    "Latin_ext": "Ð (U+00D0); emphatics Ṣ Ḍ Ṭ Ẓ (dot-below rule); Ɐ (U+2C6F)",
    "Vowel_semivowel": "Three Waws (O/U/W) and three Yaas (E/I/Y)",
    "Borrowed": "C and J — restricted to code-switched words in original spelling only"
  }
}
